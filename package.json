{
  "name": "daylight-saviour",
  "version": "0.0.0",
  "private": true,
  "description": "Daylight Saviour product monorepo",
  "license": "Apache-2.0",
  "packageManager": "npm@11.16.0",
  "engines": {
    "node": ">=24.18.0 <25",
    "npm": ">=11.16.0 <12"
  },
  "workspaces": [
    "apps/*",
    "services/*",
    "packages/*"
  ],
  "allowScripts": {
    "fsevents@2.3.3": true,
    "unrs-resolver": false
  },
  "overrides": {
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-test-renderer": "19.2.3",
    "uuid": "11.1.1"
  },
  "scripts": {
    "android": "npm run android --workspace @daylight-saviour/mobile",
    "audit": "npm audit --audit-level=moderate",
    "dependencies:check": "npm ls react react-dom react-test-renderer uuid && npm run doctor",
    "doctor": "npm exec --workspace=@daylight-saviour/mobile -- expo-doctor",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "eslint .",
    "native:generate:android": "npm exec --workspace=@daylight-saviour/mobile -- expo prebuild --platform android --clean --no-install",
    "start": "npm run start --workspace @daylight-saviour/mobile",
    "test": "npm run test --workspace @daylight-saviour/mobile -- --runInBand",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "web": "npm run web --workspace @daylight-saviour/mobile",
    "web:export": "npm exec --workspace=@daylight-saviour/mobile -- expo export --platform web"
  },
  "devDependencies": {
    "eslint": "9.39.2",
    "eslint-config-expo": "57.0.0",
    "expo-doctor": "1.20.0",
    "prettier": "3.8.1",
    "typescript": "~6.0.3"
  }
}
